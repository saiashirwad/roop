{
  "name": "@roop/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --env-file=../../.env --import tsx --watch src/main.ts",
    "start": "node --env-file=../../.env --import tsx src/main.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@effect/platform-node": "4.0.0-beta.94",
    "@roop/core": "workspace:*",
    "@roop/pack": "workspace:*",
    "@roop/rpc": "workspace:*",
    "effect": "4.0.0-beta.94"
  },
  "devDependencies": {
    "@effect/vitest": "4.0.0-beta.94",
    "@types/node": "^26.1.1",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
